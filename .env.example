# Restaurant Live Billing System - Firebase Environment Variables Template
# Copy this file to .env.local and fill in your actual credentials.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Counter login usernames shown on the login page.
# In Firebase mode, create these users in Firebase Authentication using the emails below.
VITE_COUNTER_B1_USERNAME=b1
VITE_COUNTER_B1_EMAIL=b1@frydaddy.local
VITE_COUNTER_B2_USERNAME=b2
VITE_COUNTER_B2_EMAIL=b2@frydaddy.local

# Local demo mode only, used when Firebase is not configured.
# Do not rely on browser-stored demo passwords for production security.
VITE_COUNTER_B1_PASSWORD=b1
VITE_COUNTER_B2_PASSWORD=b2

