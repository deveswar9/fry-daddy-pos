rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Anyone authenticated (anonymously or otherwise) can read/write seating states
    match /tables/{tableId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Anyone authenticated can manage orders and order sub-collections
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      
      match /timeline/{entryId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Anyone authenticated can manage active order items
    match /orderItems/{itemId} {
      allow read, write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Menu items can be read by anyone, modified by authenticated managers/counters
    match /menu/{menuItemId} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
    
    // Payments tracking collection
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }
  }
}

